{{!-- Sans-serif font is always loaded, because it's the default font for some part of the theme regardless of the settings --}}
{{> partials/typography/sans}}

{{#match @root.custom.title_font "Modern sans-serif"}}
    {{#match @root.custom.body_font "Elegant serif"}}
        {{> partials/typography/serif}}
    {{/match}}
{{else match @root.custom.title_font "Elegant serif"}}
    {{> partials/typography/serif}}
{{else}}
    {{> partials/typography/mono}}
    {{#match @root.custom.body_font "Elegant serif"}}
        {{> partials/typography/serif}}
    {{/match}}
{{/match}}