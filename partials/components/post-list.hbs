{{!--
    Parameters:
    * feed (index, home, archive, recent)
    * postFeedStyle (list, grid)
    * showTitle (true, false)
    * showSidebar (true, false)
--}}

<section class="gh-container is-{{#match postFeedStyle "List"}}list{{else}}grid{{/match}}{{#if showSidebar}} has-sidebar{{/if}}{{#unless @root.custom.show_images_in_feed}} no-image{{/unless}} gh-outer">
    <div class="gh-container-inner gh-inner">
        
        {{#if showTitle}}
            <h2 class="gh-container-title">
                {{#unless title}}Latest{{else}}{{title}}{{/unless}}
            </h2>
        {{/if}}

        <main class="gh-main">
            <div class="gh-feed">

                {{!-- Homepage --}}
                {{#match feed "home"}}
                    {{#match @root.custom.header_style "Highlight"}}
                        {{#if @root.custom.show_featured_posts}}
                            {{#match (length posts) ">=" 4}}
                                {{#get "posts" include="authors" limit="16"}}
                                    {{#foreach posts from="5"}}
                                        {{> partials/post-card lazyLoad=true}}
                                    {{/foreach}}
                                {{/get}}
                            {{/match}}
                        {{else}}
                            {{#match (length posts) ">=" 10}}
                                {{#get "posts" include="authors" limit="22"}}
                                    {{#foreach posts from="11"}}
                                        {{> partials/post-card lazyLoad=true}}
                                    {{/foreach}}
                                {{/get}}
                            {{/match}}
                        {{/if}}
                    {{else match @root.custom.header_style "Magazine"}}
                        {{#match (length posts) ">=" 7}}
                            {{#get "posts" include="authors" limit="19"}}
                                {{#foreach posts from="8"}}
                                    {{> partials/post-card lazyLoad=true}}
                                {{/foreach}}
                            {{/get}}
                        {{/match}}
                    {{else}}
                        {{#get "posts" include="authors" limit="12"}}
                            {{#foreach posts}}
                                {{> partials/post-card lazyLoad=true}}
                            {{/foreach}}
                        {{/get}}
                    {{/match}}
                {{/match}}

                {{!-- All posts --}}
                {{#match feed "index"}}
                    {{#match pagination.page 2}}
                        {{#get "posts" include="authors" limit=@root.config.posts_per_page as |recent|}}
                            {{#foreach recent}}
                                {{> partials/post-card}}
                            {{/foreach}}
                        {{/get}}
                    {{/match}}
                    {{#foreach posts}}
                        {{> partials/post-card lazyLoad=true}}
                    {{/foreach}}
                {{/match}}

                {{!-- Tag and author pages --}}
                {{#match feed "archive"}}
                    {{#foreach posts}}
                        {{> partials/post-card lazyLoad=true}}
                    {{/foreach}}
                {{/match}}

            </div>

            {{#match pagination.pages ">" 1}}
                <div class="gh-more is-title">
                    <a href="{{@root.site.url}}/page/2">See all {{> partials/icons/arrow}}</a>
                </div>
            {{/match}}
        </main>

        {{#if showSidebar}}
            <aside class="gh-sidebar">
                <div class="gh-sidebar-inner">
                    <section class="gh-about">
                        {{#if @root.site.icon}}
                            <img class="gh-about-icon" src="{{@root.site.icon}}" alt="{{@root.site.title}}" loading="lazy">
                        {{/if}}
                        <h3 class="gh-about-title is-title">{{@root.site.title}}</h3>
                        {{#if @root.site.description}}
                            <p class="gh-about-description is-body">{{@root.site.description}}</p>
                        {{/if}}
                        {{#if @root.site.members_enabled}}
                            {{#unless @root.member}}
                                <button class="gh-button" data-portal="signup">Subscribe</button>
                            {{else}}
                                {{#if @root.site.paid_members_enabled}}
                                    {{#unless @root.member.paid}}
                                        <button class="gh-button" data-portal="upgrade">Upgrade</button>
                                    {{/unless}}
                                {{/if}}
                            {{/unless}}
                        {{/if}}
                    </section>
                    {{#if @root.site.recommendations_enabled}}
                        <section class="gh-recommendations">
                            <h4 class="gh-sidebar-title">Recommendations</h4>
                            {{recommendations}}
                            <button data-portal="recommendations">See all {{> partials/icons/arrow}}</button>
                        </section>
                    {{/if}}
                </div>
            </aside>
        {{/if}}

    </div>
</section>